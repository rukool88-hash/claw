# Obsidian
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/*/data.json

# 音频原始文件不入库（仅留 transcripts）
inbox/audio/*
!inbox/audio/.gitkeep

# 系统/编辑器
.DS_Store
Thumbs.db
*.tmp
*.swp

# Python (本地服务在仓库外，但以防 venv 出现在此)
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# Claude Code 本地状态
.claude/cache/
.claude/sessions/
.claude/maintain.log

# Qwen Code 本地状态
.qwen/cache/
.qwen/sessions/
.qwen/maintain.log
.qwen/*.orig

# n8n 运行数据（含 sqlite、加密凭证）和环境变量文件
infra/n8n/data/
infra/n8n/.env
**/.env
!**/.env.example

# 临时图片
*.png
!docs/**/*.png

# polling offset cache
.cache/

